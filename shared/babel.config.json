{
    "presets": [
        "@babel/preset-env",
        "@babel/preset-typescript"
    ],
    "plugins": [
        [
            "module-resolver",
            {
                "alias": {
                    "@constants": "./dist/constants",
                    "@lib": "./dist/lib",
                    "@ctypes": "./dist/types",
                    "@resources": "./resources"
                }
            }
        ]
    ]
}